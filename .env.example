# PA — environment variables (Linux / Docker / systemd).
# On macOS the scripts read from Keychain first; env vars are the fallback.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# -- Mail accounts ------------------------------------------------------------
# Comma-separated list of account ids. Each id maps to a set of PA_MAIL_<ID>_*
# vars below. Leave blank to use a single implicit "example" account.
PA_MAIL_ACCOUNTS=

# Credentials for each account. Repeat the block per id, upper-case.
# Example for id "example":
PA_MAIL_EXAMPLE_USER=
PA_MAIL_EXAMPLE_PASS=
PA_MAIL_EXAMPLE_IMAP_HOST=
PA_MAIL_EXAMPLE_IMAP_PORT=993
PA_MAIL_EXAMPLE_SMTP_HOST=
PA_MAIL_EXAMPLE_SMTP_PORT=587
PA_MAIL_EXAMPLE_FROM_NAME=

# -- Telegram bot (optional) --------------------------------------------------
# Token from @BotFather and the allowed chat id (only this chat is accepted).
PA_TELEGRAM_BOT_TOKEN=
PA_TELEGRAM_CHAT_ID=

# -- Slack (optional) ---------------------------------------------------------
# Member id of the Slack account whose DMs / mentions the watcher checks.
# Get it from Slack → profile → "Copy member ID".
PA_SLACK_USER_ID=

# -- Follow-up watcher (optional) ----------------------------------------------
# Days without reply before a sent mail triggers a follow-up nudge.
PA_FOLLOWUP_DAYS=4
# Sent folder name per account if it isn't "Sent" (e.g. "Sent Messages").
# PA_MAIL_EXAMPLE_SENT_FOLDER=

# -- Meeting prep (optional) ----------------------------------------------------
# Comma-separated domains considered "internal"; attendees outside them make
# a meeting external. Defaults to the domain of the first mail account.
PA_OWN_DOMAINS=

# -- Memory sync (Mac side, optional) -------------------------------------------
# Used by scripts/memory_sync.sh to converge the two memory dirs.
PA_SYNC_SSH=
PA_SYNC_MEMORY_DIR=
PA_SYNC_MEMORY_OWNER=
